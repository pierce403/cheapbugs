{
  "name": "cheapbugs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/fix-xmtp-wasm-worker.mjs",
    "prebuild": "node scripts/fix-xmtp-wasm-worker.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "contracts:build": "forge build",
    "contracts:test": "forge test",
    "launch:bug-index": "node scripts/launch-bug-index.mjs",
    "launch:bug-index:dry-run": "node scripts/launch-bug-index.mjs --dry-run",
    "launch:bug-index:forge": "bash scripts/launch-bug-index-forge.sh --broadcast",
    "launch:bug-index:forge:dry-run": "bash scripts/launch-bug-index-forge.sh"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@xmtp/browser-sdk": "^6.1.2",
    "ethers": "^6.16.0",
    "thirdweb": "5.119.4",
    "viem": "^2.47.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "typescript": "^5.8.3",
    "vite": "^7.1.7"
  },
  "overrides": {
    "ws": "8.20.1",
    "uuid": "11.1.1"
  }
}
